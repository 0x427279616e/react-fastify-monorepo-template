{
   "name": "@template/api",
   "version": "1.0.0",
   "description": "project template",
   "main": "dist/index.js",
   "directories": {
      "test": "test"
   },
   "scripts": {
      "test": "node --import tsx --test test/**/*.test.ts",
      "dev": "tsx watch src/index.ts | pino-pretty",
      "start": "node dist/index.js | pino-pretty",
      "build": "tsc",
      "server": "node dist/index.js",
      "db:gen": "kysely-codegen --out-file ./src/config/database/types.gen.ts --no-camel-case",
      "db:migrate": "tsx src/migrate.ts",
      "db:rollback": "tsx src/migrate-down.ts"
   },
   "keywords": [],
   "author": "",
   "license": "ISC",
   "dependencies": {
      "@aws-sdk/client-s3": "^3.816.0",
      "@aws-sdk/s3-request-presigner": "^3.1019.0",
      "@fastify/autoload": "^5.10.0",
      "@fastify/compress": "^7.0.3",
      "@fastify/cors": "^9.0.1",
      "@fastify/jwt": "^7.2.0",
      "@fastify/multipart": "^8.3.0",
      "@fastify/mysql": "^4.3.0",
      "@fastify/sensible": "^5.6.0",
      "@fastify/static": "^7.0.4",
      "@getbrevo/brevo": "^3.0.1",
      "@template/shared": "workspace:*",
      "@sinclair/typebox": "^0.34.49",
      "@types/node": "^20.14.10",
      "basic-ftp": "^5.0.5",
      "bcryptjs": "^2.4.3",
      "cluster": "^0.7.7",
      "dotenv": "^16.4.5",
      "fastify": "^4.28.1",
      "fastify-bcrypt": "^1.0.1",
      "fastify-cli": "^6.2.1",
      "fastify-cors": "^6.1.0",
      "fastify-plugin": "^4.5.1",
      "fastify-static": "^4.6.1",
      "googleapis": "^144.0.0",
      "kysely": "^0.29.2",
      "multer": "^1.4.5-lts.1",
      "mysql2": "^3.22.4",
      "nodemailer": "^7.0.11",
      "nodemon": "^3.1.4",
      "p-limit": "^5.0.0",
      "path": "^0.12.7",
      "pino-pretty": "^11.0.0",
      "sharp": "^0.33.5",
      "slugify": "^1.6.6",
      "ssh2-sftp-client": "^11.0.0",
      "tsx": "^4.22.3",
      "uuid": "^11.0.3",
      "xlsx": "^0.18.5"
   },
   "devDependencies": {
      "kysely-codegen": "^0.20.0",
      "typescript": "^6.0.3"
   }
}
